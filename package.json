{
  "name": "discord-clone",
  "version": "1.0.0",
  "description": "Discord clone with React, Node.js, Socket.io, and WebRTC",
  "scripts": {
    "check": "node check-servers.js",
    "start-backend": "cd backend && npm run dev",
    "start-frontend": "cd frontend && npm run dev",
    "install-all": "cd backend && npm install && cd ../frontend && npm install",
    "dev": "concurrently \"npm run start-backend\" \"npm run start-frontend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  },
  "keywords": ["discord", "clone", "chat", "webrtc", "socket.io"],
  "author": "",
  "license": "MIT"
}
